# =====================================================
# PROJECT CAMP - Backend Environment Configuration
# =====================================================
# For ssipmt.com training project with domain-restricted registration

# Server Configuration
NODE_ENV=development
PORT=8000

# Frontend URLs (update these for your deployment)
CORS_ORIGIN=http://localhost:5173,https://your-frontend-domain.com
FRONTEND_URL=http://localhost:5173

# MongoDB Atlas Connection
MONGO_URI=mongodb+srv://username:password@cluster.xxx.mongodb.net/projectcamp

# JWT Authentication Tokens
ACCESS_TOKEN_SECRET=your-secure-access-token-secret-key-here
ACCESS_TOKEN_EXPIRY=15m

REFRESH_TOKEN_SECRET=your-secure-refresh-token-secret-key-here
REFRESH_TOKEN_EXPIRY=10d

# Cookie Settings
COOKIE_SAME_SITE=lax
# For production with HTTPS: set to 'none' if frontend and backend are on different domains

# Domain Restriction
# Only allow registrations from ssipmt.com domain
ALLOWED_EMAIL_DOMAIN=ssipmt.com

# =====================================================
# EMAIL / SMTP Configuration
# =====================================================
# Using Gmail with App Password (recommended)
# Steps:
#   1. Enable 2FA on your Gmail: https://myaccount.google.com/security
#   2. Generate an App Password: https://myaccount.google.com/apppasswords
#   3. Set SMTP_USER to your Gmail address and SMTP_PASS to the 16-char App Password
SMTP_SERVICE=gmail
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=vermaketan1006@gmail.com
SMTP_PASS=nzth yzgl nslp xjkk

# Email From Address
EMAIL_FROM="ProjectCamp <vermaketan1006@gmail.com>"
SMTP_REJECT_UNAUTHORIZED=true

# =====================================================
# Development Settings
# =====================================================
# Show OTP in API response (development only, set to false in production)
SHOW_EMAIL_OTP=true

# =====================================================
# Password Reset & Redirect URLs
# =====================================================
# Update these to match your frontend domain
FORGOT_PASSWORD_REDIRECT_URL=http://localhost:5173/reset-password

# Server URL (used for attachment URLs in task files)
SERVER_URL=http://localhost:8000