PORT=8000
CORS_ORIGIN=http://localhost:5173
# Optional: restrict registration to one organization, for example ssipmt.com.
# Leave blank to allow all valid email domains during development.
ALLOWED_EMAIL_DOMAIN=
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.example.mongodb.net/projectcamp

ACCESS_TOKEN_SECRET=youraccesssecret
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_SECRET=yourrefreshsecret
REFRESH_TOKEN_EXPIRY=10d
# In production, use `none` only when the frontend and API are on different HTTPS origins.
COOKIE_SAME_SITE=lax

# Use your actual SMTP provider. For Gmail, set SMTP_SERVICE=gmail and use an app password.
SMTP_SERVICE=gmail
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your.email@gmail.com
SMTP_PASS=your-gmail-app-password

# Optional Mailtrap alias variables for local development
MAILTRAP_SMTP_HOST=sandbox.smtp.mailtrap.io
MAILTRAP_SMTP_PORT=2525
MAILTRAP_SMTP_USER=your-mailtrap-user
MAILTRAP_SMTP_PASS=your-mailtrap-pass

# Use a from address that matches your SMTP identity when possible.
EMAIL_FROM="ProjectCamp <your.email@gmail.com>"

# In development, the backend can return the OTP directly so you can verify the flow without waiting for email delivery.
SHOW_EMAIL_OTP=false

FRONTEND_URL=http://localhost:5173
FORGOT_PASSWORD_REDIRECT_URL=http://localhost:5173/reset-password
